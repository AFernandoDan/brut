{
  "name": "brut",
  "version": "1.0.0",
  "description": "Libreria de componentes brutalistas en React y Vite",
  "type": "module",
  "main": "./dist/brut.cjs",
  "module": "./dist/brut.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/brut.es.js",
      "require": "./dist/brut.cjs"
    },
    "./style.css": "./dist/brut.css"
  },
  "scripts": {
    "dev": "vite",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:types && vite build",
    "preview": "vite preview",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "react",
    "vite",
    "component-library",
    "brutalist"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.8.0",
    "vite": "^8.1.0"
  }
}
